#!/bin/sh
# Reject commits that include non-empty secrets in tracked appsettings*.json

root="$(git rev-parse --show-toplevel)" || exit 1
script="$root/core/SyncPlatform/scripts/validate-committed-appsettings.ps1"

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$script" -Staged
  exit $?
fi

if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$script" -Staged
  exit $?
fi

echo "pre-commit: PowerShell (pwsh) required to validate appsettings secrets." >&2
exit 1
