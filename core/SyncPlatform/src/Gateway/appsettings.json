{
    "$schema":  "https://json.schemastore.org/appsettings.json",
    "_comment":  "YARP reverse-proxy routes for local microservices. JWT comes from configs/appsettings.Shared*.json.",
    "Logging":  {
                    "LogLevel":  {
                                     "Yarp":  "Warning"
                                 }
                },
    "Cors":  {
                 "AllowedOrigins":  [
                                        "*"
                                    ]
             },
    "ReverseProxy":  {
                         "Routes":  {
                                        "iam-auth-route":  {
                                                               "ClusterId":  "iam-cluster",
                                                               "Match":  {
                                                                             "Path":  "/api/v1/auth/{**catch-all}"
                                                                         }
                                                           },
                                        "iam-me-route":  {
                                                             "ClusterId":  "iam-cluster",
                                                             "AuthorizationPolicy":  "AuthenticatedUser",
                                                             "Match":  {
                                                                           "Path":  "/api/v1/me/{**catch-all}"
                                                                       }
                                                         },
                                        "iam-biometrics-route":  {
                                                                     "ClusterId":  "iam-cluster",
                                                                     "AuthorizationPolicy":  "AuthenticatedUser",
                                                                     "Match":  {
                                                                                   "Path":  "/api/v1/biometrics/{**catch-all}"
                                                                               }
                                                                 },
                                        "roadmap-route":  {
                                                              "ClusterId":  "roadmap-cluster",
                                                              "AuthorizationPolicy":  "AuthenticatedUser",
                                                              "Match":  {
                                                                            "Path":  "/api/v1/roadmap/{**catch-all}"
                                                                        },
                                                              "Transforms":  [
                                                                                 {
                                                                                     "PathRemovePrefix":  "/api/v1/roadmap"
                                                                                 },
                                                                                 {
                                                                                     "PathPrefix":  "/api/v1"
                                                                                 }
                                                                             ]
                                                          },
                                        "exercise-route":  {
                                                               "ClusterId":  "exercise-cluster",
                                                               "AuthorizationPolicy":  "AuthenticatedUser",
                                                               "Match":  {
                                                                             "Path":  "/api/v1/exercise/{**catch-all}"
                                                                         },
                                                               "Transforms":  [
                                                                                  {
                                                                                      "PathRemovePrefix":  "/api/v1/exercise"
                                                                                  },
                                                                                  {
                                                                                      "PathPrefix":  "/api/v1"
                                                                                  }
                                                                              ]
                                                           },
                                        "notification-route":  {
                                                                   "ClusterId":  "notification-cluster",
                                                                   "AuthorizationPolicy":  "AuthenticatedUser",
                                                                   "Match":  {
                                                                                 "Path":  "/api/v1/notification/{**catch-all}"
                                                                             },
                                                                   "Transforms":  [
                                                                                      {
                                                                                          "PathRemovePrefix":  "/api/v1/notification"
                                                                                      },
                                                                                      {
                                                                                          "PathPrefix":  "/api/v1"
                                                                                      }
                                                                                  ]
                                                               },
                                        "payment-payos-webhook-route":  {
                                                                            "ClusterId":  "payment-cluster",
                                                                            "Match":  {
                                                                                          "Path":  "/api/v1/payment/payments/payos/webhook"
                                                                                      },
                                                                            "Transforms":  [
                                                                                               {
                                                                                                   "PathRemovePrefix":  "/api/v1/payment"
                                                                                               },
                                                                                               {
                                                                                                   "PathPrefix":  "/api/v1"
                                                                                               }
                                                                                           ]
                                                                        },
                                        "payment-route":  {
                                                              "ClusterId":  "payment-cluster",
                                                              "AuthorizationPolicy":  "AuthenticatedUser",
                                                              "Match":  {
                                                                            "Path":  "/api/v1/payment/{**catch-all}"
                                                                        },
                                                              "Transforms":  [
                                                                                 {
                                                                                     "PathRemovePrefix":  "/api/v1/payment"
                                                                                 },
                                                                                 {
                                                                                     "PathPrefix":  "/api/v1"
                                                                                 }
                                                                             ]
                                                          }
                                    },
                         "Clusters":  {
                                          "iam-cluster":  {
                                                              "LoadBalancingPolicy":  "RoundRobin",
                                                              "HealthCheck":  {
                                                                                  "Active":  {
                                                                                                 "Enabled":  true,
                                                                                                 "Interval":  "00:00:30",
                                                                                                 "Timeout":  "00:00:10",
                                                                                                 "Policy":  "ConsecutiveFailures",
                                                                                                 "Path":  "/health"
                                                                                             }
                                                                              },
                                                              "Destinations":  {
                                                                                   "iam/primary":  {
                                                                                                       "Address":  "http://localhost:5288"
                                                                                                   }
                                                                               }
                                                          },
                                          "roadmap-cluster":  {
                                                                  "LoadBalancingPolicy":  "RoundRobin",
                                                                  "HealthCheck":  {
                                                                                      "Active":  {
                                                                                                     "Enabled":  true,
                                                                                                     "Interval":  "00:00:30",
                                                                                                     "Timeout":  "00:00:10",
                                                                                                     "Policy":  "ConsecutiveFailures",
                                                                                                     "Path":  "/health"
                                                                                                 }
                                                                                  },
                                                                  "Destinations":  {
                                                                                       "roadmap/primary":  {
                                                                                                               "Address":  "http://localhost:5118"
                                                                                                           }
                                                                                   }
                                                              },
                                          "exercise-cluster":  {
                                                                   "LoadBalancingPolicy":  "RoundRobin",
                                                                   "HealthCheck":  {
                                                                                       "Active":  {
                                                                                                      "Enabled":  true,
                                                                                                      "Interval":  "00:00:30",
                                                                                                      "Timeout":  "00:00:10",
                                                                                                      "Policy":  "ConsecutiveFailures",
                                                                                                      "Path":  "/health"
                                                                                                  }
                                                                                   },
                                                                   "Destinations":  {
                                                                                        "exercise/primary":  {
                                                                                                                 "Address":  "http://localhost:5187"
                                                                                                             }
                                                                                    }
                                                               },
                                          "notification-cluster":  {
                                                                       "LoadBalancingPolicy":  "RoundRobin",
                                                                       "HealthCheck":  {
                                                                                           "Active":  {
                                                                                                          "Enabled":  true,
                                                                                                          "Interval":  "00:00:30",
                                                                                                          "Timeout":  "00:00:10",
                                                                                                          "Policy":  "ConsecutiveFailures",
                                                                                                          "Path":  "/health"
                                                                                                      }
                                                                                       },
                                                                       "Destinations":  {
                                                                                            "notification/primary":  {
                                                                                                                         "Address":  "http://localhost:5106"
                                                                                                                     }
                                                                                        }
                                                                   },
                                          "payment-cluster":  {
                                                                  "LoadBalancingPolicy":  "RoundRobin",
                                                                  "HealthCheck":  {
                                                                                      "Active":  {
                                                                                                     "Enabled":  true,
                                                                                                     "Interval":  "00:00:30",
                                                                                                     "Timeout":  "00:00:10",
                                                                                                     "Policy":  "ConsecutiveFailures",
                                                                                                     "Path":  "/health"
                                                                                                 }
                                                                                  },
                                                                  "Destinations":  {
                                                                                       "payment/primary":  {
                                                                                                               "Address":  "http://localhost:5084"
                                                                                                           }
                                                                                   }
                                                              }
                                      }
                     }
}
