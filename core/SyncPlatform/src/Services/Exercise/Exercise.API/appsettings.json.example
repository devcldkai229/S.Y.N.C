{
  "$schema": "https://json.schemastore.org/appsettings.json",

  "ConnectionStrings": {
    "ExerciseDatabase": "mongodb://localhost:27018"
  },

  "MongoDB": {
    "ExerciseDatabaseName": "sync_exercise"
  },

  "AWS": {
    "Profile": "default",
    "Region": "ap-southeast-1"
  },

  "Storage": {
    "Bucket": "sync-public-assets",
    "KeyPrefix": "exercises_catalog/",
    "PublicRead": true,
    "UseMediaProxy": true,
    "MediaProxyBaseUrl": "http://localhost:5057/api/v1/exercise/exercises/media/",
    "MaxFileSizeMb": 50,
    "MaxThumbnailSizeMb": 5,
    "AllowedImageContentTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp"
    ],
    "AllowedVideoContentTypes": [
      "video/mp4",
      "video/mpeg",
      "video/quicktime",
      "video/webm"
    ]
  },

  "FreeExerciseDb": {
    "JsonUrl": "https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/dist/exercises.json",
    "ImageBaseUrl": "https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/"
  },

  "Translate": {
    "Provider": "passthrough"
  },
  "Enrichment": {
    "OllamaBaseUrl": "http://localhost:11434",
    "Model": "qwen2.5:latest",
    "Temperature": 0.2,
    "Concurrency": 2
  }
}
