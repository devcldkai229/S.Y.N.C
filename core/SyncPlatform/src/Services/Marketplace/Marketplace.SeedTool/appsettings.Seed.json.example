{
  "ConnectionStrings": {
    "MarketplaceDatabase": "mongodb://localhost:27018"
  },
  "MongoDB": {
    "MarketplaceDatabaseName": "sync_marketplace"
  },
  "AWS": {
    "Profile": "<your-aws-profile>",
    "Region": "ap-southeast-1"
  },
  "Storage": {
    "Bucket": "sync-public-assets",
    "KeyPrefix": "food_catalog/",
    "PublicBaseUrl": "http://localhost:5057/api/v1/media",
    "PublicRead": true
  },
  "Pexels": {
    "ApiKey": "<pexels-api-key>",
    "MinDelayMs": 350,
    "MaxRetries": 3
  }
}
