# Database (pgvector). For docker use the compose host name sync-ai-postgres.
DATABASE_URL=postgresql+asyncpg://ai_user:ai_secure_pass@localhost:5435/sync_ai_agent

# DeepSeek LLM (reuse the same key configured for the Notification service)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# JWT — must match configs/appsettings.Shared.Development.json
JWT_SECRET_KEY=uANeK_nCAd:N$p2_<&C5?V|#5HDX4vMfIe1)lOf^{_{
JWT_ISSUER=sync-lifestyle-iam-dev
JWT_AUDIENCE=sync-lifestyle-clients-dev

# Inter-service URLs (direct, not via gateway)
EXERCISE_SERVICE_URL=http://localhost:5187
IAM_SERVICE_URL=http://localhost:5288
ROADMAP_SERVICE_URL=http://localhost:5118

# Embedding
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_TOP_K=12
