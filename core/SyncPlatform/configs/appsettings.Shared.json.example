{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "_readme": "Copy to appsettings.Shared.json (gitignored). JWT shared by all services — never commit real SecretKey.",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "Jwt": {
    "Issuer": "sync-lifestyle-iam",
    "Audience": "sync-lifestyle-clients",
    "SecretKey": "REPLACE_WITH_MIN_32_CHAR_SECRET",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  }
}
