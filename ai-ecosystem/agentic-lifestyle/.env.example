# Copy to .env in this directory (gitignored)

SYNC_DEBUG=true
SYNC_HOST=0.0.0.0
SYNC_PORT=8100

# Required — https://console.groq.com
SYNC_GROQ_API_KEY=

# Agent brain (Phase 4)
SYNC_OPENAI_API_KEY=
SYNC_GROQ_ROUTER_MODEL=llama-3.1-8b-instant
SYNC_OPENAI_WORKER_MODEL=gpt-4o-mini
SYNC_NUTRITION_GUARDRAIL_MAX_RETRIES=3

# RabbitMQ (async commands → C# consumers)
SYNC_RABBITMQ_URL=amqp://sync_mq_user:SyncMqSecurePassword2026@localhost:5672/
SYNC_RABBITMQ_EXCHANGE=sync.agent.commands
SYNC_RABBITMQ_WORKOUT_QUEUE=workout_commands
SYNC_RABBITMQ_ENABLED=true
SYNC_IDEMPOTENCY_TTL_SEC=86400
SYNC_GROQ_STT_MODEL=whisper-large-v3
SYNC_GROQ_STT_LANGUAGE=vi

# TravisVN Edge TTS (OpenAI-compatible)
SYNC_TTS_BASE_URL=https://tts.travisvn.com/v1
SYNC_TTS_API_KEY=not-needed
SYNC_TTS_MODEL=openai-edge-tts
SYNC_TTS_VOICE=vi-VN-HoaiMyNeural
SYNC_TTS_RESPONSE_FORMAT=mp3

# Incoming audio from Flutter (PCM s16le)
SYNC_AUDIO_SAMPLE_RATE=16000
SYNC_AUDIO_CHANNELS=1
SYNC_AUDIO_MAX_BUFFER_BYTES=26214400

# JIT context (C# Gateway — never connect Python to IAM/Roadmap DBs)
SYNC_GATEWAY_BASE_URL=http://localhost:5057
SYNC_GATEWAY_TIMEOUT_SEC=15
SYNC_GATEWAY_MAX_RETRIES=3
SYNC_GATEWAY_RETRY_BACKOFF_SEC=0.5

# Workout RAG (pgvector — Python-only per architecture)
SYNC_PGVECTOR_DSN=postgresql://postgres:12345@localhost:5434/sync_vector
SYNC_PGVECTOR_EXERCISE_TABLE=exercise_catalog
SYNC_PGVECTOR_EMBEDDING_MODEL=BAAI/bge-m3
SYNC_PGVECTOR_SEARCH_LIMIT=3
